<style>
.not-found {
    text-align: center;
    padding: 50px 20px;
}
.not-found h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: 48px;
    font-weight: 700;
    color: black;
    margin-bottom: 20px;
}
.not-found p {
    font-family: 'Lato', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: black;
    margin-bottom: 20px;
}
.not-found .cta-button {
    background-color: #00BFFF;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s;
}
.not-found .cta-button:hover {
    background-color: #0099CC;
}
</style>

<section class="not-found">
    <h1>404 - Page Not Found</h1>
    <p>The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="cta-button">Return to Homepage</a>
</section>
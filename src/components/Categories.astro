<style>
.categories {
    padding: 50px 20px;
    text-align: center;
}
.categories h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 32px;
    font-weight: 600;
    color: black;
    margin-bottom: 20px;
}
.categories .categories-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
}
.category-card {
    background: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    transition: box-shadow 0.3s;
}
.category-card:hover {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}
.category-card .icon {
    font-size: 24px;
    margin-bottom: 10px;
}
.category-card .title {
    font-family: 'Lato', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: black;
}
</style>

<section class="categories">
    <h2>Explore Topics</h2>
    <div class="categories-list">
        <!-- Category cards go here -->
        <div class="category-card">
            <div class="icon">💪</div>
            <h3 class="title">Strength Training</h3>
        </div>
        <div class="category-card">
            <div class="icon">❤️</div>
            <h3 class="title">Cardio</h3>
        </div>
        <!-- Add more category cards as needed -->
    </div>
</section>
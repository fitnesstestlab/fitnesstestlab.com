<style>
.sidebar {
    width: 300px;
    flex-shrink: 0;
    padding: 20px;
    background: #f8f8f8;
    border-radius: 8px;
}
.sidebar .author-info,
.sidebar .search-bar,
.sidebar .categories-list,
.sidebar .ads,
.sidebar .related-articles {
    margin-bottom: 20px;
}
.sidebar .author-info img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin-bottom: 10px;
}
.sidebar h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: black;
    margin-bottom: 10px;
}
.sidebar .author-info p,
.sidebar .categories-list ul,
.sidebar .ads p,
.sidebar .related-articles ul {
    font-family: 'Lato', sans-serif;
    font-size: 14px;
    color: #666;
}
.categories-list ul,
.related-articles ul {
    list-style: none;
    padding: 0;
}
.categories-list ul li,
.related-articles ul li {
    margin-bottom: 10px;
}
.categories-list ul li a,
.related-articles ul li a {
    color: #00BFFF;
    text-decoration: none;
}
.categories-list ul li a:hover,
.related-articles ul li a:hover {
    text-decoration: underline;
}
</style>

<aside class="sidebar">
    <div class="author-info">
        <img src="/path/to/author-photo.jpg" alt="Author Photo">
        <h3>About the Author</h3>
        <p>Jane Doe is a fitness enthusiast with over 10 years of experience in home workouts and training. Follow her on social media for more tips and guides.</p>
    </div>
    <div class="search-bar">
        <h3>Search</h3>
        <input type="text" placeholder="Search..." />
    </div>
    <div class="categories-list">
        <h3>Related Categories</h3>
        <ul>
            <li><a href="/categories/fitness">Fitness</a></li>
            <li><a href="/categories/nutrition">Nutrition</a></li>
            <li><a href="/categories/wellness">Wellness</a></li>
        </ul>
    </div>
    <div class="ads">
        <h3>Advertisements</h3>
        <p>Your ad here</p>
    </div>
    <div class="related-articles">
        <h3>Related Articles</h3>
        <ul>
            <li><a href="/blog/how-to-stay-motivated">How to Stay Motivated for Home Workouts</a></li>
            <li><a href="/blog/best-home-workout-equipment">10 Best Home Workout Equipment</a></li>
        </ul>
    </div>
</aside>
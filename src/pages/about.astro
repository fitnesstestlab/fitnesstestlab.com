---
import Header from '../components/Header.astro';
import AboutPageHeader from '../components/AboutPageHeader.astro';
import AboutContent from '../components/AboutContent.astro';
import AuthorBios from '../components/AuthorBios.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us - Fitness Test Lab</title>
    <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
    <Header />
    <main>
        <AboutPageHeader />
        <div class="content-area">
            <AboutContent />
            <AuthorBios />
        </div>
    </main>
    <Footer />
</body>
</html>

<style>
.content-area {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
}
</style>